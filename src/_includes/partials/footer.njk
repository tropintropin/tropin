<footer>
  <p>
    <button id="theme-toggle" class="theme-toggle">
      <span class="icon">🌓</span>
      <span class="label">Тема</span>
    </button>
  </p>

  <div class="footer-inner">
    <div>
      {% for icon in social_icons.icons %}
        <a
          href="{{ icon.url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="{{ icon.name }}"
          class="icon-link"
        >
          <svg width="24" height="24" class="footer-icon">
            <use xlink:href="#icon-{{ icon.name | lower }}"></use>
          </svg>
        </a>
      {% endfor %}
    </div>

    <small>
      <a
        href="/wish"
        title="На случай, если вы думаете мне что-то подарить"
      >Wish List
      </a>
      <span class="separator">·</span>
      <a
        href="{{ site.calendar.url }}"
        target="_blank"
        rel="me noopener noreferrer"
        title="{{ site.calendar.title }}"
        >Events Calendar</a
      >
      <span class="separator">·</span>
      <a
        href="{{ site.feed.url }}"
        target="_blank"
        rel="me noopener noreferrer"
        title="{{ site.feed.title }}"
        >RSS</a
      >
      <span class="separator">·</span>
      <a
          href="/legal"
          title="Legal notice and privacy policy"
        >Legal & Privacy</a>
      <span class="separator">·</span>
      <a
        href="/map"
        title="Карта сайта"
        >All pages</a
      >
    </small>

    <p class="footer-copy">
  &copy;&nbsp;<time datetime="2023-2026">MMXXIII&nbsp;→&nbsp;MMXXVI</time>&nbsp;<a href="{{ site.url }}">{{ author.enFullName }}</a>.
  Built with <a href="https://www.11ty.dev/" target="_blank" rel="noopener">11ty</a>, sourced on <a href="https://about.gitlab.com/" target="_blank" rel="noopener">GitLab</a> & hosted by <a href="https://timeweb.cloud/" target="_blank" rel="noopener">Timeweb Cloud</a>. Mirror available at <a href="https://mirror.tropin.one" target="_blank" rel="noopener">mirror.tropin.one</a>.
</p>
  </div>
</footer>
